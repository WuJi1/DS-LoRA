{
    "model_name": "Llama3-8B",
    "layers": [
        4,
        5,
        6,
        7,
        8
    ],
    "layer_selection": "all",
    "fact_token": "last",
    "rewrite_module_tmp": "model.layers.{}.mlp.down_proj",
